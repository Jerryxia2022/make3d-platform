NODE_ENV=production
APP_URL=https://make3d.com.cn
DATABASE_URL=file:/app/data/make3d.db
UPLOAD_DIR=/app/uploads

ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=
COOKIE_SECURE=false
ADMIN_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

PRUSASLICER_ENABLED=false
