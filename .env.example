APP_URL=http://localhost:3000
NEXT_PUBLIC_ICP_BEIAN=
DATABASE_URL=file:./data/make3d.db
UPLOAD_DIR=./uploads

ADMIN_USERNAME=
ADMIN_PASSWORD=
SESSION_SECRET=
COOKIE_SECURE=false
REDIS_URL=
ADMIN_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

WECHAT_MP_ENABLED=false
WECHAT_MP_APP_ID=
WECHAT_MP_APP_SECRET=
WECHAT_MP_TOKEN=
WECHAT_MP_AES_KEY=

PRUSASLICER_ENABLED=false
PRUSASLICER_BIN=prusa-slicer
PRUSASLICER_PROFILE_PATH=/app/profiles/bambu-p1s.ini
SLICE_TIMEOUT_SECONDS=120
MAX_SLICE_CONCURRENCY=1

# Localhost-only WSL order workbench. The systemd service remains bound to
# 127.0.0.1:5177 and stores verified order files under one directory per order.
LOCAL_ORDER_FILES_ROOT=/srv/make3d-worker/files
